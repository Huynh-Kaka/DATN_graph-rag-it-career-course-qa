# Logging: DEBUG | INFO | WARNING | ERROR | CRITICAL (mặc định INFO)
LOG_LEVEL=INFO

# Google Gemini (bước 1: LLM qua API — lấy key tại https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
# D-03: LLM-as-judge — gemini | openai | groq | local (local khuyến nghị nếu có proxy)
# Chạy: python scripts/smoke_judge.py && python scripts/eval_answer_quality.py
JUDGE_PROVIDER=local
JUDGE_LOCAL_MODEL=
JUDGE_GROQ_API_KEY=
GROQ_API_KEY=
JUDGE_GROQ_MODEL=llama-3.1-8b-instant
JUDGE_GROQ_BASE_URL=https://api.groq.com/openai/v1
JUDGE_OPENAI_API_KEY=
JUDGE_OPENAI_MODEL=gpt-4o-mini
JUDGE_GEMINI_API_KEY=
JUDGE_GEMINI_MODEL=gemini-2.5-flash-lite
JUDGE_REQUEST_DELAY_SECONDS=2.5
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-flash-lite-latest,gemini-2.5-flash

# CHATBOT_LLM_MODE: 1 = proxy LLM local trước (cần CHATBOT_LOCAL_BASE_URL); 2 = chỉ Gemini trực tiếp (khuyến nghị khi setup mới)
CHATBOT_LLM_MODE=2
# API OpenAI-compatible local — chỉ cần khi CHATBOT_LLM_MODE=1
CHATBOT_LOCAL_BASE_URL=http://localhost:8081/v1
CHATBOT_LOCAL_API_KEY=sk-chatbot-local
CHATBOT_LOCAL_MODEL=gemini-3.5-flash-thinking@think=2

# --- Timeout (giây) ---
# CHATBOT_LOCAL_TIMEOUT_SECONDS: tối đa chờ API local mỗi lần gọi (router + generator khi CHATBOT_LLM_MODE=1).
#   Gợi ý: 45–60 nhanh/fail sớm; 120 nếu model thinking chậm. Không khai báo → mặc định code 120.
CHATBOT_LOCAL_TIMEOUT_SECONDS=60
# OLLAMA_TIMEOUT_SECONDS: khi USE_LOCAL_GENERATOR=1 (Ollama fine-tune). Không khai báo → 120.
OLLAMA_TIMEOUT_SECONDS=60
# Retry generator khi lỗi tạm thời (503, timeout)
GENERATOR_RETRY_MAX_ATTEMPTS=2
GENERATOR_RETRY_BACKOFF_SECONDS=2

# Intent Router (Bước 1) — tách config khỏi Response Generator (Bước 4)
ROUTER_MODEL=
ROUTER_FALLBACK_MODELS=
ROUTER_TEMPERATURE=0.15
ROUTER_CAREER_FUZZY_THRESHOLD=80
GENERATOR_MODEL=
GENERATOR_FALLBACK_MODELS=
GENERATOR_TEMPERATURE=0.7

# OpenAI (tùy chọn)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Embedding (Qdrant index + exemplar retrieval)
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_API_KEY=
EMBEDDING_DIMENSIONS=768

# Generator: auto (theo USE_LOCAL_GENERATOR) | gemini | local
GENERATOR_BACKEND=auto
USE_LOCAL_GENERATOR=0
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_PATHFINDING=career-pathfinding
OLLAMA_MODEL_COURSE_REC=career-course-rec
GENERATOR_CONFIDENCE_THRESHOLD=0.45

# Neo4j Aura (hoặc local: bolt://localhost:7687)
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Qdrant Cloud
QDRANT_URL=https://xxxxxxxx.us-east-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=career_roadmap

# A-03: điểm cộng graph-aware rerank khi vector doc khớp subgraph Neo4j
RETRIEVAL_GRAPH_BOOST=0.15

# E-03: RRF fusion (K và pool size; clamp 20–80 / 30–80 trong config)
RETRIEVAL_RRF_K=60
RETRIEVAL_RRF_POOL_SIZE=60
# G3: tối đa số edge doc trong top-k sau rerank (0–5)
RETRIEVAL_MAX_EDGE_IN_TOP_K=2

# competency_relation intent riêng (scoring router + follow-up)
COMPETENCY_RELATION_ENRICH=1
COMPETENCY_RELATION_INTENT_ENABLED=1
COMPETENCY_RELATION_MIN_COVERAGE=0.40
COMPETENCY_RELATION_ROUTE_THRESHOLD=3.0

# B-02: 1 = eval fail-fast khi Qdrant/embedding lỗi; 0 = fallback samples (production)
RETRIEVAL_STRICT=0

# Neon PostgreSQL (Pooled connection string)
DATABASE_URL=postgresql://USER:PASS@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_ECHO=false

# Sidebar lịch sử chat: chỉ phiên có created_at >= mốc (để trống = không lọc).
# Áp dụng cả sidebar VÀ khôi phục tin nhắn (phiên cũ trong localStorage sẽ bị bỏ qua).
# Dùng UTC (Z). Ví dụ "0h ngày 25/6 giờ VN" (UTC+7): 2026-06-24T17:00:00Z
# SESSION_FILTER_AFTER=2026-06-25T00:00:00Z

# =====================================================================
# DOCKER-FIRST (docker compose) — mật khẩu DB local dựng bằng Docker.
# Chỉ cần khi chạy `docker compose up`. Nếu để trống sẽ dùng default an toàn cho dev.
# LƯU Ý: khi chạy bằng Docker, compose TỰ ghi đè NEO4J_URI / QDRANT_URL / DATABASE_URL
# để trỏ tới tên service (neo4j / qdrant / postgres) — KHÔNG dùng giá trị cloud ở trên.
# =====================================================================
# Mật khẩu Neo4j cho container (khớp NEO4J_AUTH của service neo4j)
NEO4J_LOCAL_PASSWORD=neo4jpassword
# PostgreSQL container
POSTGRES_USER=career
POSTGRES_PASSWORD=careerpass
POSTGRES_DB=careerdb

# Đường dẫn file alias domain (tùy chọn — mặc định data/domain_aliases.json)
# DOMAIN_ALIASES_PATH=data/domain_aliases.json
